#!/bin/sh
# Usage: agent-workspace <command> [args...]

set -e

IMAGE_NAME="agent-workspace"
CONTAINER_NAME="agent-workspace"
VOLUME_MOUNTS="agent-home:/home/dev agent-cache:/home/dev/.cache"
CLEANUP_KEEP=".claude/.credentials.json .claude.json .gemini/oauth_creds.json .gemini/google_accounts.json .codex/auth.json"

if [ -n "$XDG_CONFIG_HOME" ]; then
    CONFIG_FILE="$XDG_CONFIG_HOME/agent-workspace/agent-w.conf"
else
    CONFIG_FILE="$HOME/.agent-w.conf"
fi

[ -r "$CONFIG_FILE" ] || {
    printf 'Error: config not found: %s\n' "$CONFIG_FILE" >&2
    exit 1
}

# shellcheck source=/dev/null
. "$CONFIG_FILE"

[ -n "$AGENT_WORKSPACE_HOME" ] || {
    printf 'Error: AGENT_WORKSPACE_HOME not set in config\n' >&2
    exit 1
}

SCRIPT_DIR="$AGENT_WORKSPACE_HOME"
BIN_DIR="$SCRIPT_DIR/bin"

usage() {
    cat <<EOF
Usage: agent-workspace <command> [args...]

Commands:
  run [args...]   Start container and run command (default: bash)
  build [args...] Build the Docker image (extra args go to docker build)
  update          Rebuild image from scratch, keep volumes
  cleanup         Reset volumes, keep only auth files
  doctor          Run sanity checks
  attach          Attach to running container
  stop            Stop and remove container
  status          Show container status
  prune           Remove container, volumes and image
  help            Show this help

Examples:
  agent-workspace run              # interactive shell
  agent-workspace run claude       # run Claude Code
  agent-workspace run claude-yolo  # Claude without prompts
  agent-workspace attach           # connect to running container
EOF
}

find_container() {
    docker ps -q -f "name=^${CONTAINER_NAME}$" 2>/dev/null
}

cmd_run() {
    exec "$BIN_DIR/run-agent" "$@"
}

cmd_build() {
    exec "$BIN_DIR/build-image" "$@"
}

cmd_update() {
    old_image=$(docker image inspect -f '{{.Id}}' "$IMAGE_NAME" 2>/dev/null || true)
    cmd_stop
    "$BIN_DIR/build-image" --pull --no-cache
    new_image=$(docker image inspect -f '{{.Id}}' "$IMAGE_NAME" 2>/dev/null || true)
    if [ -n "$old_image" ] && [ "$old_image" != "$new_image" ]; then
        docker image rm "$old_image" >/dev/null 2>&1 || true
    fi
    printf 'Volumes kept. Start with: agent-workspace run\n'
}

# wipe in place, credentials never touch the host
clean_home() {
    home_vol=""
    for mount in $VOLUME_MOUNTS; do
        case "$mount" in
            *:/home/dev) home_vol=${mount%%:*} ;;
        esac
    done
    [ -n "$home_vol" ] || return 0
    docker volume inspect "$home_vol" >/dev/null 2>&1 || return 0
    if ! docker image inspect "$IMAGE_NAME" >/dev/null 2>&1; then
        printf 'Image "%s" not found, skipping home cleanup\n' "$IMAGE_NAME"
        return 0
    fi

    printf 'Cleaning %s, keeping: %s\n' "$home_vol" "$CLEANUP_KEEP"

    set --
    if [ "$(uname -s)" = "Linux" ]; then
        set -- -e "HOST_UID=$(id -u)" -e "HOST_GID=$(id -g)"
    fi

    docker run --rm -i "$@" \
        -e "KEEP=$CLEANUP_KEEP" \
        -v "$home_vol:/home/dev" \
        "$IMAGE_NAME" sh -s <<'EOF'
set -e
cd /home/dev
mkdir -p /tmp/keep
for f in $KEEP; do
    [ -f "$f" ] || continue
    mkdir -p "/tmp/keep/$(dirname "$f")"
    cp -p "$f" "/tmp/keep/$f"
done
if [ -f /tmp/keep/.claude.json ]; then
    jq 'with_entries(select(.key == "oauthAccount" or .key == "userID" or .key == "hasCompletedOnboarding"))' \
        /tmp/keep/.claude.json >/tmp/keep/.claude.json.min &&
        mv /tmp/keep/.claude.json.min /tmp/keep/.claude.json
fi
find /home/dev -mindepth 1 -delete
mkdir -p .config .cache .local
cp /etc/skel/.bashrc /etc/skel/.profile . 2>/dev/null || true
cp -a /tmp/keep/. /home/dev/
EOF
}

cmd_cleanup() {
    cmd_stop
    clean_home
    for mount in $VOLUME_MOUNTS; do
        case "$mount" in
            *:/home/dev) ;;
            *:*)
                vol=${mount%%:*}
                if [ -n "$vol" ] && docker volume inspect "$vol" >/dev/null 2>&1; then
                    printf 'Removing volume %s...\n' "$vol"
                    docker volume rm "$vol" >/dev/null
                fi
                ;;
        esac
    done
}

cmd_doctor() {
    exec "$BIN_DIR/doctor" "$@"
}

cmd_attach() {
    container_id=$(find_container)
    if [ -n "$container_id" ]; then
        printf 'Attaching to %s...\n' "$CONTAINER_NAME"
        exec docker exec -it -u dev -w /workspace "$container_id" bash
    else
        printf 'No running container. Start with: agent-workspace run\n'
        exit 1
    fi
}

cmd_stop() {
    container_id=$(find_container)
    if [ -n "$container_id" ]; then
        printf 'Stopping %s...\n' "$CONTAINER_NAME"
        docker rm -f "$container_id" >/dev/null
        printf 'Done.\n'
    else
        if docker ps -aq -f "name=^${CONTAINER_NAME}$" | grep -q .; then
            printf 'Removing stopped container...\n'
            docker rm "$CONTAINER_NAME" >/dev/null
            printf 'Done.\n'
        else
            printf 'No container found.\n'
        fi
    fi
}

cmd_status() {
    container_id=$(find_container)
    if [ -n "$container_id" ]; then
        printf 'Container %s running (ID: %s)\n' "$CONTAINER_NAME" "$container_id"
        docker ps --filter "id=$container_id" --format "  Image:   {{.Image}}\n  Status:  {{.Status}}\n  Ports:   {{.Ports}}"
    else
        printf 'Container %s not running.\n' "$CONTAINER_NAME"
    fi
}

cmd_prune() {
    printf 'This removes the container, all volumes (auth included) and the image.\n'
    printf 'Continue? [y/N] '
    read -r answer
    case "$answer" in
        y | Y) ;;
        *)
            printf 'Aborted.\n'
            exit 1
            ;;
    esac
    cmd_stop
    for mount in $VOLUME_MOUNTS; do
        case "$mount" in
            *:*)
                vol=${mount%%:*}
                if [ -n "$vol" ]; then
                    docker volume rm "$vol" >/dev/null 2>&1 || true
                fi
                ;;
        esac
    done
    docker image rm "$IMAGE_NAME" >/dev/null 2>&1 || true
    printf 'Done.\n'
}

main() {
    if [ $# -eq 0 ]; then
        usage
        exit 0
    fi

    command="$1"
    shift

    case "$command" in
        run) cmd_run "$@" ;;
        build) cmd_build "$@" ;;
        update) cmd_update "$@" ;;
        cleanup) cmd_cleanup "$@" ;;
        doctor) cmd_doctor "$@" ;;
        attach) cmd_attach "$@" ;;
        stop) cmd_stop "$@" ;;
        status) cmd_status "$@" ;;
        prune) cmd_prune "$@" ;;
        help | --help | -h)
            usage
            exit 0
            ;;
        *)
            printf 'Unknown command: %s\n\n' "$command" >&2
            usage >&2
            exit 1
            ;;
    esac
}

main "$@"
